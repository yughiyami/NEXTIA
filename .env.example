# --- Database (the box's single SQLite file) ---
DB_PATH=data/nextia.db

# --- LLM routing ---
# "ollama" = local Gemma (the box). "gemini" = cloud (dev/fallback).
LLM_PROVIDER=ollama

# Ollama (local)
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_CHAT_MODEL=gemma3:4b
OLLAMA_EMBED_MODEL=nomic-embed-text

# Gemini (fallback / dev) — leave empty to disable
GEMINI_API_KEY=
GEMINI_CHAT_MODEL=gemini-2.5-flash
GEMINI_EMBED_MODEL=text-embedding-004

# --- Better Auth ---
# Generate a real secret for anything beyond local dev: openssl rand -base64 32
BETTER_AUTH_SECRET=dev-insecure-secret-change-me
# Must match the origin you open in the browser (dev runs on :3010).
BETTER_AUTH_URL=http://localhost:3010
# Extra trusted origins (comma-separated) — e.g. the box LAN IP for students.
TRUSTED_ORIGINS=
